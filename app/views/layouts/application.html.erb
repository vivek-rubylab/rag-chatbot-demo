<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>11+ Tutor Chat</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= javascript_importmap_tags %>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary-color: #2563eb;
      --secondary-color: #64748b;
      --success-color: #16a34a;
      --danger-color: #dc2626;
      --gray-100: #f1f5f9;
      --gray-200: #e2e8f0;
      --gray-300: #cbd5e1;
      --gray-700: #334155;
      --gray-900: #0f172a;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      line-height: 1.6;
      background: #f1f5f9;
      color: #0f172a;
    }
    /* ── Navbar ── */
    .navbar {
      background: #fff;
      border-bottom: 1px solid #e2e8f0;
      padding: 0.75rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .navbar-brand { font-weight: 700; font-size: 1.05rem; color: #2563eb; text-decoration: none; }
    .navbar-actions { display: flex; align-items: center; gap: 1rem; font-size: 0.875rem; }
    .navbar-actions a { color: #64748b; text-decoration: none; }
    .navbar-actions a:hover { color: #0f172a; }
    .nav-user { color: #64748b; }
    .btn-signout {
      background: transparent; border: 1px solid #e2e8f0;
      padding: 0.3rem 0.75rem; border-radius: 6px; cursor: pointer;
      font-size: 0.875rem; color: #64748b; font-family: inherit;
    }
    .btn-signout:hover { background: #f1f5f9; color: #0f172a; }
    .flash-notice { background: #f0fdf4; border-bottom: 1px solid #bbf7d0; padding: 0.5rem 1.5rem; font-size: 0.875rem; color: #16a34a; }
    .flash-alert  { background: #fef2f2; border-bottom: 1px solid #fecaca; padding: 0.5rem 1.5rem; font-size: 0.875rem; color: #dc2626; }

    /* ── Chat page ── */
    .chat-page { display: flex; justify-content: center; padding: 1.5rem 1rem 2rem; }
    .chat-window {
      width: 100%; max-width: 720px; background: #fff; border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10); display: flex; flex-direction: column;
      height: calc(100vh - 100px); min-height: 520px; overflow: hidden;
    }

    /* ── Header ── */
    .chat-header { display: flex; align-items: center; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--primary-color); color: #fff; flex-shrink: 0; }
    .chat-header-avatar { font-size: 1.75rem; line-height: 1; }
    .chat-header-name { font-weight: 700; font-size: 1rem; }
    .chat-header-status { font-size: 0.8rem; opacity: 0.85; display: flex; align-items: center; gap: 0.35rem; }
    .status-dot { display: inline-block; width: 8px; height: 8px; background: #4ade80; border-radius: 50%; box-shadow: 0 0 0 2px rgba(74,222,128,0.35); }

    /* ── Messages ── */
    .chat-messages {
      flex: 1; overflow-y: auto; padding: 1.25rem 1rem;
      display: flex; flex-direction: column; gap: 0.5rem; background: #f8fafc;
    }

    /* ── Welcome ── */
    .chat-welcome { text-align: center; padding: 2.5rem 1rem; color: var(--secondary-color); }
    .chat-welcome-icon { font-size: 3rem; margin-bottom: 0.75rem; }
    .chat-welcome h3 { font-size: 1.25rem; color: var(--gray-900); margin-bottom: 0.5rem; }
    .chat-welcome p { font-size: 0.95rem; margin-bottom: 1.25rem; }
    .chat-welcome-suggestions { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }
    .suggestion-chip {
      background: #fff; border: 1.5px solid var(--gray-300); border-radius: 20px;
      padding: 0.45rem 1rem; font-size: 0.85rem; color: var(--primary-color);
      cursor: pointer; transition: all 0.15s; font-family: inherit;
    }
    .suggestion-chip:hover { background: var(--primary-color); color: #fff; border-color: var(--primary-color); }

    /* ── Message rows ── */
    .msg { display: flex; align-items: flex-end; gap: 0.5rem; max-width: 78%; }
    .msg--user      { align-self: flex-end; flex-direction: row-reverse; }
    .msg--assistant { align-self: flex-start; }

    /* ── Avatars ── */
    .msg-avatar { font-size: 1.4rem; flex-shrink: 0; width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; line-height: 1; }
    .msg-avatar--bot  { background: #eff6ff; }
    .msg-avatar--user { background: #dbeafe; }

    /* ── Bubbles ── */
    .msg-body { display: flex; flex-direction: column; gap: 0.2rem; }
    .msg--user      .msg-body { align-items: flex-end; }
    .msg--assistant .msg-body { align-items: flex-start; }
    .msg-bubble { padding: 0.65rem 1rem; border-radius: 18px; font-size: 0.95rem; line-height: 1.55; word-break: break-word; }
    .msg--user      .msg-bubble { background: var(--primary-color); color: #fff; border-bottom-right-radius: 4px; }
    .msg--assistant .msg-bubble { background: #fff; color: var(--gray-900); border: 1px solid var(--gray-200); border-bottom-left-radius: 4px; box-shadow: 0 1px 2px rgba(0,0,0,0.06); }
    .msg-bubble p { margin: 0 0 0.4rem; }
    .msg-bubble p:last-child { margin-bottom: 0; }
    .msg-bubble strong { font-weight: 700; }
    .msg-time { font-size: 0.72rem; color: var(--secondary-color); padding: 0 0.25rem; }

    /* ── Thinking dots ── */
    .msg-bubble--thinking { display: flex; gap: 5px; align-items: center; padding: 0.8rem 1rem; min-width: 60px; }
    .dot { display: inline-block; width: 8px; height: 8px; background: var(--gray-300); border-radius: 50%; animation: bounce 1.3s ease-in-out infinite; }
    .dot:nth-child(2) { animation-delay: 0.18s; }
    .dot:nth-child(3) { animation-delay: 0.36s; }
    @keyframes bounce {
      0%, 60%, 100% { transform: translateY(0);    opacity: 0.5; }
      30%            { transform: translateY(-7px); opacity: 1;   }
    }

    /* ── Streaming bubble ── */
    /* Bubble fades in once when it first replaces the thinking dots */
    .msg-bubble--streaming {
      animation: bubbleFadeIn 0.2s ease-out;
    }
    /* pre-wrap prevents the browser from collapsing spaces at the edges of
       adjacent inline .stream-token spans (e.g. "Year" + " 4" → "Year4") */
    .stream-text { white-space: pre-wrap; }
    @keyframes bubbleFadeIn {
      from { opacity: 0; transform: translateY(3px); }
      to   { opacity: 1; transform: translateY(0);   }
    }
    /* Each delta chunk fades in independently — existing text never moves */
    .stream-token {
      animation: tokenFadeIn 0.35s ease-out forwards;
    }
    @keyframes tokenFadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    /* Blinking cursor after the text via ::after on the bubble */
    .msg-bubble--streaming::after {
      content: '';
      display: inline-block; width: 2px; height: 0.9em;
      background: var(--primary-color); margin-left: 2px;
      vertical-align: text-bottom; border-radius: 1px;
      animation: blink 0.85s step-end infinite;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0; }
    }

    /* ── Error ── */
    #chat-error { padding: 0 1rem; background: #f8fafc; flex-shrink: 0; }
    .chat-error-msg { background: #fef2f2; color: var(--danger-color); border: 1px solid #fecaca; border-radius: 8px; padding: 0.65rem 1rem; font-size: 0.9rem; }

    /* ── Composer ── */
    .chat-composer { padding: 0.75rem 1rem 0.6rem; border-top: 1px solid var(--gray-200); background: #fff; flex-shrink: 0; }
    .composer-inner {
      display: flex; align-items: flex-end; gap: 0.5rem;
      background: #f1f5f9; border: 1.5px solid var(--gray-300);
      border-radius: 24px; padding: 0.5rem 0.5rem 0.5rem 1rem; transition: border-color 0.2s;
    }
    .composer-inner:focus-within { border-color: var(--primary-color); background: #fff; }
    .composer-input {
      flex: 1; border: none !important; background: transparent !important;
      font-size: 0.95rem; font-family: inherit; line-height: 1.4; resize: none;
      outline: none !important; box-shadow: none !important;
      color: var(--gray-900); max-height: 120px; overflow-y: auto;
      padding: 0 !important;
    }
    .composer-input::placeholder { color: var(--secondary-color); }
    .composer-send {
      flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%;
      background: var(--primary-color); color: #fff; border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s, transform 0.1s; padding: 0;
    }
    .composer-send:hover  { background: #1d4ed8; }
    .composer-send:active { transform: scale(0.92); }
    .composer-hint { font-size: 0.72rem; color: var(--secondary-color); text-align: center; margin-top: 0.4rem; }
  </style>
</head>
<body>

  <nav class="navbar">
    <a href="/" class="navbar-brand">🤖 11+ Tutor Chat</a>
    <div class="navbar-actions">
      <% if user_signed_in? %>
        <span class="nav-user"><%= current_user.email %></span>
        <%= button_to "Sign out", destroy_user_session_path, method: :delete,
              class: "btn-signout" %>
      <% else %>
        <%= link_to "Sign in", new_user_session_path %>
      <% end %>
    </div>
  </nav>

  <% if notice.present? %>
    <div class="flash-notice"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div class="flash-alert"><%= alert %></div>
  <% end %>

  <%= yield %>

</body>
</html>
